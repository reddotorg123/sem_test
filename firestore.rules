rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * 🔐 CORE AUTHENTICATION & ROLE HELPERS
     */
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Safely get user document fields without failing on null
    function getUserData() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data
        : {"role": "public", "teamId": null};
    }

    function isAdmin() {
      return getUserData().role == "admin";
    }

    function isManager() {
      return getUserData().role == "event_manager";
    }

    function getTeamId() {
      return getUserData().teamId;
    }

    /**
     * 🌍 GLOBAL & PERSONAL EVENTS
     * Holds the shared catalog of events and any private user-created events.
     */
    match /events/{eventId} {
      // READ: Authenticated users can read the catalog.
      allow read: if isSignedIn(); 

      // CREATE: Only Admin/Manager can create global events (no teamId).
      // Everyone else can create team events but ONLY for their own team.
      allow create: if isSignedIn() && (
        isAdmin() || isManager() || (
          request.resource.data.teamId != null && 
          request.resource.data.teamId == getTeamId()
        )
      );

      // UPDATE/DELETE: Only Admins/Managers OR the creator can modify.
      allow update, delete: if isAdmin() || isManager() || (resource != null && resource.data.createdBy == request.auth.uid);
    }

    /**
     * 👥 USER PROFILES
     * Handles authentication, roles (Admin, Subscriber, Manager, Public), and team membership.
     */
    match /users/{userId} {
      // READ: Everyone can view basic profiles to enable team discovery and invites.
      allow read: if isSignedIn();
      
      // CREATE: Initial registration as "public".
      allow create: if isOwner(userId) && request.resource.data.role == "public";
      
      // UPDATE: (1) Admin/Manager Console (2) User Self-Service (3) Team Leader Updates Member Position
      allow update: if isAdmin() || (
                      isOwner(userId) && (
                        // Role Protection: Self-upgrade is strictly forbidden.
                        // Only let users stay at their current role or lower it to 'public'.
                        (request.resource.data.role == resource.data.role || request.resource.data.role == "public") &&
                        (request.resource.data.email == resource.data.email)
                      )
                    ) || (
                      isSignedIn() && 
                      resource.data.teamId == request.auth.uid && 
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['position'])
                    );

      // DELETE: Restricted to Admins (Soft-delete is handled via update role: 'deleted').
      allow delete: if isAdmin();
    }

    /**
     * 📊 TEAM EVENT DATA (Status/Prize Tracking)
     * Stores private team-specific or user-specific progress ON specific events.
     * DOCUMENT ID: {teamId}_{eventId} or {userId}_{eventId}
     */
    match /teamEventData/{docId} {
      // Check if user belongs to the associated team or is the individual owner
      function isMemberOfTeam(targetTeamId) {
        return targetTeamId == request.auth.uid || targetTeamId == getTeamId();
      }

      allow read: if isSignedIn() && (isMemberOfTeam(resource.data.teamId) || isAdmin());
      allow create: if isSignedIn() && isMemberOfTeam(request.resource.data.teamId);
      allow update: if isSignedIn() && isMemberOfTeam(resource.data.teamId);
      allow delete: if isAdmin() || (isSignedIn() && isMemberOfTeam(resource.data.teamId));
    }

    /**
     * 👤 INDIVIDUAL USER NOTES (Fully Private)
     */
    match /notes/{noteId} {
      allow read, write: if isSignedIn() && (
        (resource != null && resource.data.createdBy == request.auth.uid) ||
        (request.resource != null && request.resource.data.createdBy == request.auth.uid)
      );
    }

    /**
     * 🏛 COLLEGE REPOSITORY
     */
    match /colleges/{collegeId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isManager();
    }

    /**
     * 💳 PAYMENT VERIFICATION (Billing Grid)
     */
    match /payment_requests/{requestId} {
      // User creates as 'pending'.
      allow create: if isSignedIn() && 
                    request.resource.data.userId == request.auth.uid && 
                    request.resource.data.status == "pending";
      
      // Reading: Admin sees all, User sees their own.
      allow read: if isAdmin() || (resource != null && resource.data.userId == request.auth.uid);
      
      // Processing: Only Admins can approve/reject/delete.
      allow update, delete: if isAdmin();
    }

    /**
     * ⚙️ SYSTEM SETTINGS
     */
    match /settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    /**
     * 💬 TEAM MESSAGES (Intel Channel)
     * READ: Allow any signed-in user to query — security enforced via client-side
     *       where("teamId", "==", teamId) filter. Only members know their own teamId.
     * WRITE: Only members of the target team can create messages.
     */
    match /team_messages/{messageId} {
      allow read: if isSignedIn() && (
        resource.data.teamId == request.auth.uid || 
        resource.data.teamId == getTeamId() || 
        isAdmin()
      );
      allow create: if isSignedIn() && (
        request.resource.data.teamId == request.auth.uid || 
        request.resource.data.teamId == getTeamId()
      );
      allow update, delete: if isAdmin() || (resource != null && resource.data.senderId == request.auth.uid);
    }
  }
}
